# =============================================================================
# ENVIRONMENT VARIABLES — Copy this file to .env and fill in your values.
# .env is git-ignored. NEVER commit real credentials to source control.
# =============================================================================

# GitHub API Configuration
# Docusaurus reads this as DOCUSAURUS_GIT_TOKEN (prefix required by the loader)
# Create a token at: https://github.com/settings/tokens
# No special permissions needed for public repositories.
DOCUSAURUS_GIT_TOKEN=your_github_personal_access_token_here

# Shopify Storefront API (for Merch Store)
# These are injected at build-time via docusaurus.config.ts → customFields.
# NOTE: The Storefront Access Token is a READ-ONLY public token by Shopify design,
# but hardcoding it in source code is still an anti-pattern — keep it here.
#
# How to obtain:
#   Shopify Admin → Settings → Apps and sales channels → Develop apps
#   Required scopes: unauthenticated_read_product_listings, unauthenticated_write_checkouts
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# Firebase Configuration (if needed)
# FIREBASE_API_KEY=your_firebase_api_key
# FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
# FIREBASE_PROJECT_ID=your_firebase_project_id

# Analytics
# GOOGLE_ANALYTICS_ID=your_google_analytics_id
# VERCEL_ANALYTICS_ID=your_vercel_analytics_id
